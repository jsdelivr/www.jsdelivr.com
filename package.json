	"scripts": {
		"postinstall": "patch-package",
		"build": "gulp build",
		"heroku-postbuild": "echo \"$SOURCE_VERSION\" > sha.txt",
		"lint": "npm run lint:css && npm run lint:html && npm run lint:js",
		"lint:fix": "npm run lint:css:fix && npm run lint:html:fix && npm run lint:js:fix",
		"lint:css": "stylelint --config .stylelintrc \"./src/**/*.{css,less}\"",
		"lint:css:fix": "stylelint --fix --config .stylelintrc \"./src/**/*.{css,less}\"",
		"lint:html": "eslint --config eslint-html.config.js --cache-location .eslintcache-html --cache \"**/*.html\"",
		"lint:html:fix": "eslint --config eslint-html.config.js --cache-location .eslintcache-html --cache --fix \"**/*.html\"",
		"lint:js": "eslint --cache .",
		"lint:js:fix": "eslint --cache --fix .",
		"mocha": "mocha --exit test/tests.js",
		"prepare": "husky",
		"start": "cross-env NODE_ENV=development gulp",
		"test": "npm run lint && npm run mocha"
	},
	"lint-staged": {
		"*.{css,less}": "stylelint --fix",
		"*.{html,js}": "eslint --cache --fix",
		"*.html": "eslint --config eslint-html.config.js --cache-location .eslintcache-html --cache --fix"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/jsdelivr/www.jsdelivr.com.git"
